            "context": 128000,
            "output": 65536
          }
        },
        "gemma4:latest": {
          "name": "gemma4:latest",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        },
        "gemma:latest": {
          "name": "gemma:latest",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        },
        "glm-4.7-flash:latest": {
          "name": "glm-4.7-flash:latest",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        },
        "glm-4.7:cloud": {
          "name": "glm-4.7:cloud",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        },
        "glm-ocr:latest": {
          "name": "glm-ocr:latest",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        },
        "gpt-oss:latest": {
          "name": "gpt-oss:latest",
          "limit": {
            "context": 128000,
            "output": 65536
          }
