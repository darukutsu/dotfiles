{
	"$schema": "https://opencode.ai/config.json",
	"lsp": true,
	"formatter": true,
	"disabled_providers": [],
	"plugin": [
		//"oh-my-openagent", // configure first
		"@tarquinen/opencode-dcp@latest",
		"opencode-notify",
		//remove this once opencode releases official local discovery
		"opencode-models-discovery"
		//"github:JuliusBrussee/caveman"
		//"opencode-pty",
		//"opencode-websearch-cited",
		//"opencode-jfrog-plugin",
		//"opencode-antigravity-auth",
		//"opencode-gemini-auth",
		//"opencode-firecrawl",
	],
	"provider": {
		// single model server, figure out deployment & distribution
		// benefit of huggingface models
		//"vllm": {
		//	"npm": "@ai-sdk/openai-compatible",
		//	"name": "vLLM (local)",
		//	"options": {
		//		"baseURL": "http://vllm.ai.lan/v1"
		//	}
		//},
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://ollama.ai.lan/v1"
			}
		}
	},
	"agent": {
		"build": {
			"mode": "primary",
			"permission": {
				"read": "allow",
				"edit": "allow",
				"bash": {
					"*": "ask",
					"awk *": "allow",
					"basename *": "allow",
					//"bash *": "allow",
					"cat *": "allow",
					"cut *": "allow",
					"df *": "allow",
					"diff *": "allow",
					"dirname *": "allow",
					"echo *": "allow",
					"find *": "allow",
					"git diff *": "allow",
					"git log *": "allow",
					"git status *": "allow",
					"grep *": "allow",
					"head *": "allow",
					"ls *": "allow",
					"printf *": "allow",
					"sed *": "allow",
					"seq *": "allow",
					//"sh *": "allow",
					"sleep *": "allow",
					"sort *": "allow",
					"tail *": "allow",
					"tr *": "allow",
					"wc *": "allow"
					//"xargs *": "allow",
				},
				"grep": "allow",
				"glob": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"skill": "allow",
				"webfetch": "allow"
			}
		},
		"review": {
			"temperature": 0.2,
			//"model": "deepseek-coder",
			"description": "Reviews code for best practices and potential issues",
			"disable": true
		}
	},
	"permission": {
		"bash": {
			"*": "ask",
			"awk *": "allow",
			"basename *": "allow",
			//"bash *": "allow",
			"cat *": "allow",
			"curl *": "allow",
			"cut *": "allow",
			"df *": "allow",
			"diff *": "allow",
			"dirname *": "allow",
			"echo *": "allow",
			"find *": "allow",
			"git diff *": "allow",
			"git log *": "allow",
			"git status *": "allow",
			"grep *": "allow",
			"head *": "allow",
			"ls *": "allow",
			"printf *": "allow",
			"sed *": "allow",
			"seq *": "allow",
			//"sh": "allow",
			"sleep *": "allow",
			"sort *": "allow",
			"tail *": "allow",
			"tr *": "allow"
			//"xargs": "allow",
		}
	}
}
