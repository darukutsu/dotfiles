{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://api.ai.lan/v1"
			},
			"models": {
				"codellama": {
					"_launch": true,
					"name": "codellama"
				},
				"deepseek-coder": {
					"_launch": true,
					"name": "deepseek-coder"
				},
				"deepseek-r1": {
					"_launch": true,
					"name": "deepseek-r1"
				},
				"devstral-2": {
					"_launch": true,
					"name": "devstral-2"
				},
				"gemma": {
					"_launch": true,
					"name": "gemma"
				},
				"gemma3": {
					"_launch": true,
					"name": "gemma3"
				},
				"gemma4": {
					"_launch": true,
					"name": "gemma4"
				},
				"glm-4.7-flash": {
					"_launch": true,
					"name": "glm-4.7-flash"
				},
				"huihui_ai/qwen3-coder-abliterated": {
					"_launch": true,
					"name": "huihui_ai/qwen3-coder-abliterated"
				},
				"huihui_ai/qwen3-coder-next-abliterated": {
					"_launch": true,
					"name": "huihui_ai/qwen3-coder-next-abliterated"
				},
				"llama2-uncensored": {
					"_launch": true,
					"name": "llama2-uncensored"
				},
				"llama3.3": {
					"_launch": true,
					"name": "llama3.3"
				},
				"mistral": {
					"_launch": true,
					"name": "mistral"
				},
				"qwen": {
					"_launch": true,
					"name": "qwen"
				},
				"qwen2.5-coder": {
					"_launch": true,
					"name": "qwen2.5-coder"
				},
				"qwen3-coder": {
					"_launch": true,
					"name": "qwen3-coder"
				},
				"qwen3-coder-next": {
					"_launch": true,
					"name": "qwen3-coder-next"
				},
				"qwen3.5": {
					"_launch": true,
					"name": "qwen3.5"
				},
				"starcoder": {
					"_launch": true,
					"name": "starcoder"
				}
			}
		}
	},
	"agent": {
		"build": {
			"mode": "primary",
			"permission": {
				"read": "allow",
				"edit": "allow",
				"bash": {
					"*": "ask",
					"awk": "allow",
					"basename": "allow",
					//"bash": "allow",
					"cat": "allow",
					"cut": "allow",
					"df": "allow",
					"diff": "allow",
					"dirname": "allow",
					"echo": "allow",
					"find": "allow",
					"git diff *": "allow",
					"git log *": "allow",
					"git status *": "allow",
					"grep": "allow",
					"head": "allow",
					"ls": "allow",
					"printf": "allow",
					"sed": "allow",
					"seq": "allow",
					//"sh": "allow",
					"sleep": "allow",
					"sort": "allow",
					"tail": "allow",
					"tr": "allow"
					//"xargs": "allow",
				},
				"grep": "allow",
				"glob": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"skill": "allow",
				"webfetch": "allow"
			}
		},
		"review": {
			"temperature": 0.2,
			//"model": "deepseek-coder",
			"description": "Reviews code for best practices and potential issues",
			"disable": true
		}
	},
	"permission": {
		"bash": {
			"*": "ask",
			"awk": "allow",
			"basename": "allow",
			//"bash": "allow",
			"cat": "allow",
			"curl": "allow",
			"cut": "allow",
			"df": "allow",
			"diff": "allow",
			"dirname": "allow",
			"echo": "allow",
			"find": "allow",
			"git diff *": "allow",
			"git log *": "allow",
			"git status *": "allow",
			"grep": "allow",
			"head": "allow",
			"ls": "allow",
			"printf": "allow",
			"sed": "allow",
			"seq": "allow",
			//"sh": "allow",
			"sleep": "allow",
			"sort": "allow",
			"tail": "allow",
			"tr": "allow"
			//"xargs": "allow",
		}
	}
}
