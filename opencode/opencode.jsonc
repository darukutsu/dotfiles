{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"ollama": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Ollama (local)",
			"options": {
				"baseURL": "http://api.ai.lan/v1"
			},
			"models": {
				"codellama": {
					"_launch": true,
					"name": "codellama"
				},
				"devstral-2": {
					"_launch": true,
					"name": "devstral-2"
				},
				"gemma3": {
					"_launch": true,
					"name": "gemma3"
				},
				"llama3.3": {
					"_launch": true,
					"name": "llama3.3"
				},
				"mistral": {
					"_launch": true,
					"name": "mistral"
				},
				"qwen2.5-coder": {
					"_launch": true,
					"name": "qwen2.5-coder"
				},
				"qwen3.5": {
					"_launch": true,
					"name": "qwen3.5"
				},
				"glm-4.7-flash": {
					"_launch": true,
					"name": "glm-4.7-flash"
				},
				"starcoder": {
					"_launch": true,
					"name": "starcoder"
				}
			}
		}
	},
	"permission": {
		"read": "allow",
		//"edit": "allow",
		"bash": "allow",
		"grep": "allow",
		"glob": "allow",
		"list": "allow",
		"lsp": "allow",
		"question": "allow"
		//"skill": "allow",
		//"webfetch": "allow",
	}
}
